<!DOCTYPE html>
<html lang="es">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>PDF Deep Search & Exporter - Análisis Completo</title>
  <!-- Tailwind CSS -->
  <script src="https://cdn.tailwindcss.com"></script>
  <!-- PDF.js desde CDN de confianza -->
  <script src="https://cdnjs.cloudflare.com/ajax/libs/pdf.js/3.4.120/pdf.min.js"></script>
  <!-- Librerías de Exportación -->
  <script src="https://cdnjs.cloudflare.com/ajax/libs/xlsx/0.18.5/xlsx.full.min.js"></script>
  <script src="https://cdnjs.cloudflare.com/ajax/libs/jspdf/2.5.1/jspdf.umd.min.js"></script>
  <script src="https://cdnjs.cloudflare.com/ajax/libs/jspdf-autotable/3.5.29/jspdf.plugin.autotable.min.js"></script>
  <!-- Inter Font -->
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700&display=swap" rel="stylesheet">
  <style>
    body {
      font-family: 'Inter', sans-serif;
    }
    ::-webkit-scrollbar {
      width: 6px;
      height: 6px;
    }
    ::-webkit-scrollbar-track {
      background: #f1f1f1;
    }
    ::-webkit-scrollbar-thumb {
      background: #cbd5e1;
      border-radius: 4px;
    }
    ::-webkit-scrollbar-thumb:hover {
      background: #94a3b8;
    }
    .highlight-match {
      background-color: rgba(253, 224, 71, 0.7);
      border-bottom: 2px solid #eab308;
      border-radius: 2px;
      padding: 0 2px;
      color: #0f172a;
      font-weight: 600;
    }
  </style>
</head>
<body class="bg-slate-50 text-slate-800 min-h-screen flex flex-col">

  <!-- Encabezado Principal -->
  <header class="bg-gradient-to-r from-indigo-800 to-slate-900 text-white shadow-md">
    <div class="max-w-7xl mx-auto px-4 py-5 flex flex-col sm:flex-row justify-between items-center gap-4">
      <div class="flex items-center gap-3">
        <div class="bg-white/10 p-2.5 rounded-xl border border-white/20">
          <svg class="w-8 h-8 text-indigo-300" fill="none" stroke="currentColor" viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 10vd12m-6-6h12m-3-12h1.5A2.5 2.5 0 0119 5.5V17a3 3 0 01-3 3H4a3 3 0 01-3-3V5.5A2.5 2.5 0 013.5 3H5"></path>
          </svg>
        </div>
        <div>
          <h1 class="text-2xl font-bold tracking-tight">PDF Deep Search & Export</h1>
          <p class="text-xs text-indigo-200">Busca, extrae y exporta transacciones a Excel y PDF con un solo clic</p>
        </div>
      </div>
      <div class="text-xs text-indigo-100 text-right hidden md:block bg-white/5 py-1.5 px-3 rounded-lg border border-white/10">
        <p class="font-medium">Exportación Directa local</p>
        <p class="opacity-70">Formatos XLSX y PDF Autotable</p>
      </div>
    </div>
  </header>

  <!-- Contenido Principal -->
  <main class="flex-1 max-w-7xl w-full mx-auto p-4 flex flex-col gap-6">
    
    <!-- Zona de Carga de Archivo -->
    <div id="dropZone" class="bg-white border-2 border-dashed border-slate-300 hover:border-indigo-500 rounded-2xl p-10 text-center transition-all cursor-pointer shadow-sm relative overflow-hidden group">
      <input type="file" id="fileInput" accept=".pdf" class="absolute inset-0 opacity-0 cursor-pointer" />
      <div class="flex flex-col items-center justify-center gap-4">
        <div class="bg-indigo-50 text-indigo-600 p-5 rounded-full group-hover:scale-110 transition-transform shadow-xs">
          <svg class="w-12 h-12" fill="none" stroke="currentColor" viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z"></path>
          </svg>
        </div>
        <div>
          <p class="text-xl font-bold text-slate-700">Sube o arrastra tu estado de cuenta o PDF financiero aquí</p>
          <p class="text-sm text-slate-500 mt-1">Se extraerá el texto y se intentarán pre-identificar Fechas, Números de Operación, Descripciones y Abonos.</p>
          <div class="mt-4 flex justify-center gap-2">
            <span class="inline-flex items-center gap-1 bg-slate-100 text-slate-600 px-2.5 py-1 rounded-md text-xs font-medium">
              Exportar a Excel (.xlsx)
            </span>
            <span class="inline-flex items-center gap-1 bg-slate-100 text-slate-600 px-2.5 py-1 rounded-md text-xs font-medium">
              Exportar a PDF Estructurado
            </span>
          </div>
        </div>
      </div>
    </div>

    <!-- Barra de Progreso de Análisis Detallado (Oculta por defecto) -->
    <div id="progressContainer" class="hidden bg-white rounded-2xl p-6 shadow-md border border-slate-100">
      <div class="flex justify-between items-center mb-3">
        <div class="flex items-center gap-2.5">
          <span class="relative flex h-3 w-3">
            <span class="animate-ping absolute inline-flex h-full w-full rounded-full bg-indigo-400 opacity-75"></span>
            <span class="relative inline-flex rounded-full h-3 w-3 bg-indigo-600"></span>
          </span>
          <span class="font-semibold text-slate-700 text-sm md:text-base" id="progressStatus">Analizando documento...</span>
        </div>
        <span class="text-sm font-bold text-indigo-600" id="progressPercent">0%</span>
      </div>
      <div class="w-full bg-slate-100 rounded-full h-3 overflow-hidden">
        <div id="progressBar" class="bg-indigo-600 h-3 rounded-full transition-all duration-150" style="width: 0%"></div>
      </div>
      
      <!-- Consola de Indexación en Tiempo Real -->
      <div class="mt-4">
        <p class="text-xs font-bold text-slate-500 uppercase tracking-wider mb-2">Historial de Indexación y Extracción Financiera:</p>
        <div id="indexLogConsole" class="bg-slate-900 text-emerald-400 font-mono text-[11px] p-3 rounded-lg h-36 overflow-y-auto flex flex-col gap-1 shadow-inner border border-slate-800">
          <div class="text-slate-400 italic">Iniciando motor de lectura y reconocimiento estructurado...</div>
        </div>
      </div>
      <p class="text-xs text-slate-400 mt-3 text-center">Se está decodificando el texto estructurado de cada página para posibilitar búsquedas instantáneas y mapeo de datos.</p>
    </div>

    <!-- Panel de Información del Documento Activo -->
    <div id="docMetaInfo" class="hidden bg-emerald-50 border border-emerald-200 text-emerald-800 rounded-xl p-4 flex flex-wrap justify-between items-center gap-3 shadow-xs">
      <div class="flex items-center gap-2.5">
        <div class="bg-emerald-100 p-1.5 rounded-lg text-emerald-700">
          <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z"></path>
          </svg>
        </div>
        <div>
          <span class="font-bold text-slate-950 block text-sm sm:inline sm:text-base" id="loadedDocName">documento.pdf</span>
          <span class="text-xs text-emerald-700 sm:ml-2 font-medium" id="loadedDocPages">(0 páginas analizadas)</span>
        </div>
      </div>
      <div class="flex items-center gap-3">
        <span id="badgeTotalTransactions" class="bg-indigo-100 text-indigo-800 text-xs px-2.5 py-1 rounded-md font-semibold">0 transacciones extraídas</span>
        <button id="btnReset" class="text-xs text-slate-600 hover:text-red-600 font-bold transition-colors flex items-center gap-1 py-1 px-2 hover:bg-red-50 rounded-lg">
          <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 7l-.867 12.142A2 2 0 0116.138 21H7.862a2 2 0 01-1.995-1.858L5 7m5 4v6m4-6v6m1-10V4a1 1 0 00-1-1h-4a1 1 0 00-1 1v3M4 7h16"></path>
          </svg>
          Quitar archivo
        </button>
      </div>
    </div>

    <!-- Área de Trabajo Principal (Buscador y Visualizador) -->
    <div id="searchWorkspace" class="hidden grid grid-cols-1 lg:grid-cols-12 gap-6 items-start">
      
      <!-- Panel de Controles de Búsqueda (Izquierda - 4 Columnas) -->
      <section class="lg:col-span-4 flex flex-col gap-4">
        
        <div class="bg-white p-5 rounded-2xl shadow-sm border border-slate-100 flex flex-col gap-4">
          <h2 class="text-base font-bold text-slate-800 flex items-center gap-2 pb-2 border-b border-slate-100">
            <svg class="w-5 h-5 text-indigo-600" fill="none" stroke="currentColor" viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 4a1 1 0 011-1h16a1 1 0 011 1v2.586a1 1 0 01-.293.707l-6.414 6.414a1 1 0 00-.293.707V17l-4 4v-6.586a1 1 0 00-.293-.707L3.293 7.293A1 1 0 013 6.586V4z"></path>
            </svg>
            Buscador General
          </h2>

          <!-- Búsqueda por Texto / Descripción -->
          <div class="flex flex-col gap-1.5">
            <label for="searchQuery" class="text-xs font-bold text-slate-600">Descripción o palabra clave a filtrar</label>
            <div class="relative">
              <input type="text" id="searchQuery" placeholder="Ej. transferencia, compra, abono..." class="w-full pl-3 pr-8 py-2.5 border border-slate-300 rounded-lg text-sm focus:outline-none focus:ring-2 focus:ring-indigo-500 focus:border-indigo-500 shadow-xs" />
              <button id="btnClearText" class="absolute right-2.5 top-3 text-slate-400 hover:text-slate-600 hidden">
                <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"></path>
                </svg>
              </button>
            </div>
            <p class="text-[10px] text-slate-400">Filtra dinámicamente las páginas y la tabla de exportación.</p>
          </div>

          <!-- Botones de Acción -->
          <div class="flex gap-2 pt-1">
            <button id="btnSearch" class="flex-1 bg-indigo-600 hover:bg-indigo-700 text-white font-medium py-2.5 px-4 rounded-lg text-sm transition-colors shadow-sm flex items-center justify-center gap-1.5">
              <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z"></path>
              </svg>
              Buscar
            </button>
            <button id="btnResetFilters" class="border border-slate-200 hover:bg-slate-50 text-slate-600 font-medium py-2.5 px-3 rounded-lg text-sm transition-colors">
              Limpiar
            </button>
          </div>

        </div>

        <!-- Indicador de cantidad de resultados -->
        <div class="bg-indigo-50 border border-indigo-100 rounded-xl p-4 text-sm text-indigo-900 flex justify-between items-center shadow-xs">
          <span class="font-semibold">Coincidencias en páginas:</span>
          <span id="resultsCount" class="bg-indigo-600 text-white text-xs px-2.5 py-1 rounded-full font-bold">0</span>
        </div>

        <!-- Acceso Directo a Exportación Global -->
        <div class="bg-white p-5 rounded-2xl shadow-sm border border-slate-100 flex flex-col gap-3">
          <h3 class="text-xs font-bold text-slate-700 uppercase tracking-wider">Exportar Resultados Actuales</h3>
          <p class="text-[11px] text-slate-500">Puedes descargar la lista filtrada de transacciones detectadas directamente aquí.</p>
          <div class="grid grid-cols-2 gap-2">
            <button id="btnExportExcel" class="bg-emerald-600 hover:bg-emerald-700 text-white text-xs font-bold py-2.5 px-3 rounded-lg flex items-center justify-center gap-1.5 transition-colors shadow-xs">
              <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 10v6m0 0l-3-3m3 3l3-3m2 8H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z"></path>
              </svg>
              Excel (.xlsx)
            </button>
            <button id="btnExportPDF" class="bg-red-600 hover:bg-red-700 text-white text-xs font-bold py-2.5 px-3 rounded-lg flex items-center justify-center gap-1.5 transition-colors shadow-xs">
              <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 10v6m0 0l-3-3m3 3l3-3m2 8H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z"></path>
              </svg>
              PDF Tabla
            </button>
          </div>
        </div>

      </section>

      <!-- Panel de Resultados y Visualización (Derecha - 8 Columnas) -->
      <section class="lg:col-span-8 flex flex-col gap-6">
        
        <!-- Pestañas Superiores de Navegación -->
        <div class="flex border-b border-slate-200 bg-white p-2 rounded-2xl shadow-xs gap-1">
          <button id="tabButtonPages" class="flex-1 py-2.5 text-xs sm:text-sm font-bold rounded-xl transition-all bg-indigo-50 text-indigo-700">
            🔎 Buscador por Páginas
          </button>
          <button id="tabButtonTable" class="flex-1 py-2.5 text-xs sm:text-sm font-bold rounded-xl transition-all text-slate-600 hover:bg-slate-50">
            📊 Datos Extraídos & Editor (${Fecha, Op, Abonos})
          </button>
        </div>

        <!-- VISTA DE BUSCADOR POR PÁGINAS -->
        <div id="tabContentPages" class="grid grid-cols-1 md:grid-cols-2 gap-6">
          
          <!-- Listado de Coincidencias -->
          <div class="bg-white p-5 rounded-2xl shadow-sm border border-slate-100 flex flex-col h-[520px]">
            <h3 class="text-sm font-bold text-slate-800 pb-3 border-b border-slate-100 flex justify-between items-center">
              <span>Resultados de Búsqueda</span>
              <span class="text-[11px] font-normal text-slate-400">Haz clic en una página</span>
            </h3>

            <!-- Contenedor con Scroll para Resultados -->
            <div id="resultsList" class="flex-1 overflow-y-auto mt-3 pr-1 flex flex-col gap-3">
              <div class="text-center py-16 text-slate-400 flex flex-col items-center gap-2">
                <svg class="w-12 h-12 text-slate-300" fill="none" stroke="currentColor" viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 9l3 3-3 3m5 0h3M5 20h14a2 2 0 002-2V6a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z"></path>
                </svg>
                <p class="text-sm font-semibold">Esperando análisis o consulta...</p>
              </div>
            </div>
          </div>

          <!-- Previsualizador de Página del PDF -->
          <div class="bg-white p-5 rounded-2xl shadow-sm border border-slate-100 flex flex-col h-[520px]">
            <div class="flex justify-between items-center pb-3 border-b border-slate-100">
              <h3 class="text-sm font-bold text-slate-800">Visualizador de Página</h3>
              <span id="activePageIndicator" class="bg-slate-100 text-slate-700 text-[11px] px-2.5 py-1 rounded-md font-bold">Sin selección</span>
            </div>

            <!-- Contenedor del Canvas y del Texto Contextual -->
            <div class="flex-1 flex flex-col gap-3 mt-3 overflow-hidden">
              
              <!-- Selector de Vista -->
              <div class="grid grid-cols-2 gap-1 bg-slate-100 p-1 rounded-lg text-xs font-medium">
                <button id="viewModeVisual" class="py-1.5 rounded-md bg-white shadow-xs text-indigo-700 font-semibold focus:outline-none">Página Real (Render)</button>
                <button id="viewModeText" class="py-1.5 rounded-md text-slate-600 hover:bg-white/50 focus:outline-none">Texto Plano</button>
              </div>

              <!-- Contenedor del Visor Real -->
              <div class="flex-1 border border-slate-200 rounded-lg overflow-hidden bg-slate-100 relative flex items-center justify-center p-2">
                
                <!-- Loader de Rendering -->
                <div id="renderLoader" class="hidden absolute inset-0 bg-slate-900/10 backdrop-blur-xs flex items-center justify-center z-10">
                  <div class="bg-white px-4 py-2.5 rounded-lg shadow-md flex items-center gap-2 text-xs font-medium text-slate-700">
                    <span class="animate-spin rounded-full h-4 w-4 border-2 border-indigo-600 border-t-transparent"></span>
                    Obteniendo vista...
                  </div>
                </div>

                <!-- Vista Visual: Canvas del PDF -->
                <div id="visualCanvasContainer" class="w-full h-full overflow-auto flex justify-center items-start">
                  <canvas id="pdfPageCanvas" class="shadow-sm border border-slate-200 max-w-full bg-white"></canvas>
                </div>

                <!-- Vista de Texto: Texto Plano con coincidencia destacada -->
                <div id="plainTextContainer" class="hidden w-full h-full overflow-y-auto p-4 bg-slate-900 text-slate-100 font-mono text-[11px] leading-relaxed rounded-md whitespace-pre-wrap selection:bg-indigo-500">
                  Selecciona una coincidencia para visualizar el texto extraído de la página.
                </div>

              </div>

            </div>
          </div>

        </div>

        <!-- VISTA DE TABLA DE DATOS EXTRAÍDOS (EDITOR INTERACTIVO) -->
        <div id="tabContentTable" class="hidden bg-white p-5 rounded-2xl shadow-sm border border-slate-100 flex flex-col gap-4">
          <div class="flex flex-col sm:flex-row justify-between sm:items-center gap-2 pb-3 border-b border-slate-200">
            <div>
              <h3 class="text-base font-bold text-slate-800">Editor e Inspector de Datos</h3>
              <p class="text-xs text-slate-500">Revisa, edita o complementa la información detectada antes de exportar.</p>
            </div>
            <div class="flex gap-2">
              <button id="btnAddRow" class="bg-indigo-50 hover:bg-indigo-100 text-indigo-700 border border-indigo-200 text-xs font-bold py-2 px-3 rounded-lg flex items-center gap-1 transition-colors">
                <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 6v6m0 0v6m0-6h6m-6 0H6"></path>
                </svg>
                Añadir Fila
              </button>
              <button id="btnAutoParse" class="bg-amber-50 hover:bg-amber-100 text-amber-800 border border-amber-200 text-xs font-bold py-2 px-3 rounded-lg flex items-center gap-1 transition-colors" title="Vuelve a analizar el texto buscando nuevos patrones">
                ✨ Re-Escanear PDF
              </button>
            </div>
          </div>

          <!-- Contenedor de la Tabla -->
          <div class="overflow-x-auto border border-slate-200 rounded-xl max-h-[400px] overflow-y-auto">
            <table class="w-full text-left border-collapse text-xs">
              <thead>
                <tr class="bg-slate-50 border-b border-slate-200 text-slate-600 uppercase font-semibold tracking-wider">
                  <th class="py-3 px-4 w-12 text-center">Pág</th>
                  <th class="py-3 px-4 w-32">Fecha</th>
                  <th class="py-3 px-4 w-32">N° Operación</th>
                  <th class="py-3 px-4">Descripción</th>
                  <th class="py-3 px-4 w-28 text-right">Abonos ($)</th>
                  <th class="py-3 px-4 w-12 text-center">Acciones</th>
                </tr>
              </thead>
              <tbody id="transactionsTableBody" class="divide-y divide-slate-100 text-slate-700">
                <!-- Filas dinámicas añadidas por JS -->
                <tr>
                  <td colspan="6" class="text-center py-10 text-slate-400 italic">No hay transacciones cargadas. Sube un documento para iniciar.</td>
                </tr>
              </tbody>
            </table>
          </div>

          <!-- Resumen de Totales -->
          <div class="bg-slate-50 p-4 rounded-xl border border-slate-200 flex justify-between items-center text-xs">
            <span class="text-slate-500 font-medium">Filas en tabla: <strong id="tableSummaryCount" class="text-slate-800">0</strong></span>
            <span class="text-slate-700 font-bold">Monto Total Abonos: <span id="tableSummarySum" class="text-indigo-700 text-sm font-extrabold">$0.00</span></span>
          </div>

        </div>

      </section>

    </div>

  </main>

  <!-- Pie de Página -->
  <footer class="bg-slate-900 text-slate-400 text-xs py-5 border-t border-slate-800 mt-8">
    <div class="max-w-7xl mx-auto px-4 flex flex-col sm:flex-row justify-between items-center gap-2">
      <p>&copy; 2026 PDF Deep Search & Export. Procesamiento local de páginas de alta precisión.</p>
      <p class="flex items-center gap-1.5 text-slate-500 font-medium">
        <span>Garantía de análisis total de todas las páginas</span>
      </p>
    </div>
  </footer>

  <!-- Notificaciones Flotantes Personalizadas (Toasts) -->
  <div id="toastNotification" class="fixed bottom-5 right-5 z-50 bg-slate-900 text-white px-5 py-3.5 rounded-xl shadow-2xl border border-slate-700 flex items-center gap-3 translate-y-20 opacity-0 pointer-events-none transition-all duration-300">
    <div id="toastIcon" class="text-indigo-400"></div>
    <div class="flex-1">
      <p id="toastMessage" class="text-xs sm:text-sm font-medium"></p>
    </div>
    <button id="btnDismissToast" class="text-slate-400 hover:text-white ml-2">
      <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"></path>
      </svg>
    </button>
  </div>

  <!-- JavaScript del Motor de PDF y Lógica de Búsqueda -->
  <script>
    // Configurar el worker de PDF.js
    pdfjsLib.GlobalWorkerOptions.workerSrc = 'https://cdnjs.cloudflare.com/ajax/libs/pdf.js/3.4.120/pdf.worker.min.js';

    // Estados Globales de la Aplicación
    let currentPdfDoc = null;
    let pdfFileName = "";
    let extractedPages = []; // [{ pageNum: Int, text: String, charsCount: Int }]
    let extractedTransactions = []; // [{ id, page, fecha, operacion, descripcion, abono }]
    let activeResultPageNum = null;
    let currentViewMode = "visual"; // "visual" o "text"
    let currentActiveTab = "pages"; // "pages" o "table"

    // Elementos del DOM
    const dropZone = document.getElementById('dropZone');
    const fileInput = document.getElementById('fileInput');
    const progressContainer = document.getElementById('progressContainer');
    const progressBar = document.getElementById('progressBar');
    const progressStatus = document.getElementById('progressStatus');
    const progressPercent = document.getElementById('progressPercent');
    const indexLogConsole = document.getElementById('indexLogConsole');
    const docMetaInfo = document.getElementById('docMetaInfo');
    const loadedDocName = document.getElementById('loadedDocName');
    const loadedDocPages = document.getElementById('loadedDocPages');
    const badgeTotalTransactions = document.getElementById('badgeTotalTransactions');
    const btnReset = document.getElementById('btnReset');
    const searchWorkspace = document.getElementById('searchWorkspace');
    
    // Controles de Pestañas
    const tabButtonPages = document.getElementById('tabButtonPages');
    const tabButtonTable = document.getElementById('tabButtonTable');
    const tabContentPages = document.getElementById('tabContentPages');
    const tabContentTable = document.getElementById('tabContentTable');

    // Controles de Búsqueda
    const searchQueryInput = document.getElementById('searchQuery');
    const btnClearText = document.getElementById('btnClearText');
    const btnSearch = document.getElementById('btnSearch');
    const btnResetFilters = document.getElementById('btnResetFilters');
    const resultsCount = document.getElementById('resultsCount');
    const resultsList = document.getElementById('resultsList');

    // Controles de Exportación e Interacción de Tabla
    const btnAddRow = document.getElementById('btnAddRow');
    const btnAutoParse = document.getElementById('btnAutoParse');
    const transactionsTableBody = document.getElementById('transactionsTableBody');
    const tableSummaryCount = document.getElementById('tableSummaryCount');
    const tableSummarySum = document.getElementById('tableSummarySum');
    const btnExportExcel = document.getElementById('btnExportExcel');
    const btnExportPDF = document.getElementById('btnExportPDF');

    // Visor de PDF
    const activePageIndicator = document.getElementById('activePageIndicator');
    const viewModeVisualBtn = document.getElementById('viewModeVisual');
    const viewModeTextBtn = document.getElementById('viewModeText');
    const pdfPageCanvas = document.getElementById('pdfPageCanvas');
    const canvasContext = pdfPageCanvas.getContext('2d');
    const visualCanvasContainer = document.getElementById('visualCanvasContainer');
    const plainTextContainer = document.getElementById('plainTextContainer');
    const renderLoader = document.getElementById('renderLoader');

    // Toast Notificaciones
    const toastNotification = document.getElementById('toastNotification');
    const toastMessage = document.getElementById('toastMessage');
    const toastIcon = document.getElementById('toastIcon');
    const btnDismissToast = document.getElementById('btnDismissToast');

    // --- MANEJO DE NOTIFICACIONES ---
    function showToast(message, type = 'info') {
      toastMessage.textContent = message;
      
      if (type === 'error') {
        toastIcon.innerHTML = `
          <svg class="w-5 h-5 text-red-500" fill="none" stroke="currentColor" viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 9v2m0 4h.01m-6.938 4h13.856c1.54 0 2.502-1.667 1.732-3L13.732 4c-.77-1.333-2.694-1.333-3.464 0L3.34 16c-.77 1.333.192 3 1.732 3z"></path>
          </svg>
        `;
      } else if (type === 'success') {
        toastIcon.innerHTML = `
          <svg class="w-5 h-5 text-emerald-500" fill="none" stroke="currentColor" viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z"></path>
          </svg>
        `;
      } else {
        toastIcon.innerHTML = `
          <svg class="w-5 h-5 text-indigo-400" fill="none" stroke="currentColor" viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 16h-1v-4h-1m1-4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z"></path>
          </svg>
        `;
      }

      toastNotification.classList.remove('translate-y-20', 'opacity-0', 'pointer-events-none');
      toastNotification.classList.add('translate-y-0', 'opacity-100');

      setTimeout(dismissToast, 5000);
    }

    function dismissToast() {
      toastNotification.classList.add('translate-y-20', 'opacity-0', 'pointer-events-none');
      toastNotification.classList.remove('translate-y-0', 'opacity-100');
    }

    btnDismissToast.addEventListener('click', dismissToast);

    // --- EVENTOS DE CARGA ---
    ['dragenter', 'dragover'].forEach(eventName => {
      dropZone.addEventListener(eventName, (e) => {
        e.preventDefault();
        dropZone.classList.add('border-indigo-600', 'bg-indigo-50/50');
      }, false);
    });

    ['dragleave', 'drop'].forEach(eventName => {
      dropZone.addEventListener(eventName, (e) => {
        e.preventDefault();
        dropZone.classList.remove('border-indigo-600', 'bg-indigo-50/50');
      }, false);
    });

    dropZone.addEventListener('drop', (e) => {
      const dt = e.dataTransfer;
      const files = dt.files;
      if (files.length > 0) {
        handleFileSelection(files[0]);
      }
    });

    fileInput.addEventListener('change', (e) => {
      if (e.target.files.length > 0) {
        handleFileSelection(e.target.files[0]);
      }
    });

    function handleFileSelection(file) {
      if (!file) return;
      if (file.type !== 'application/pdf' && !file.name.toLowerCase().endsWith('.pdf')) {
        showToast("Extensión de archivo inválida. Por favor, sube un PDF.", "error");
        return;
      }
      pdfFileName = file.name;
      loadAndParsePDF(file);
    }

    // --- CONSOLA DE INDEXACIÓN ---
    function logToConsole(message, type = 'info') {
      const logElement = document.createElement('div');
      if (type === 'success') {
        logElement.className = "text-emerald-400 font-semibold";
      } else if (type === 'warn') {
        logElement.className = "text-yellow-400";
      } else {
        logElement.className = "text-slate-300";
      }
      logElement.textContent = `[${new Date().toLocaleTimeString()}] ${message}`;
      indexLogConsole.appendChild(logElement);
      indexLogConsole.scrollTop = indexLogConsole.scrollHeight;
    }

    // --- LECTURA PROFUNDA DE TODAS LAS PÁGINAS ---
    async function loadAndParsePDF(file) {
      dropZone.classList.add('hidden');
      progressContainer.classList.remove('hidden');
      docMetaInfo.classList.add('hidden');
      searchWorkspace.classList.add('hidden');
      
      extractedPages = [];
      extractedTransactions = [];
      activeResultPageNum = null;
      indexLogConsole.innerHTML = "";
      
      updateProgressBar(0, "Decodificando archivo PDF local...");
      logToConsole(`Abriendo archivo: ${file.name} (${(file.size/1024/1024).toFixed(2)} MB)`);

      const reader = new FileReader();
      reader.onload = async function() {
        try {
          const typedArray = new Uint8Array(this.result);
          
          const loadingTask = pdfjsLib.getDocument(typedArray);
          currentPdfDoc = await loadingTask.promise;
          const totalPages = currentPdfDoc.numPages;

          logToConsole(`Documento cargado con éxito. Total de páginas detectadas: ${totalPages}`, "success");
          updateProgressBar(10, `Indexando ${totalPages} páginas...`);

          // Procesar secuencialmente cada página
          for (let i = 1; i <= totalPages; i++) {
            updateProgressBar(
              10 + Math.floor((i / totalPages) * 85), 
              `Indexando y mapeando contenido de página ${i} de ${totalPages}...`
            );

            await new Promise(resolve => setTimeout(resolve, 10));

            const page = await currentPdfDoc.getPage(i);
            const textContent = await page.getTextContent();
            
            const pageText = textContent.items.map(item => item.str).join(' ').trim();
            const charCount = pageText.length;

            if (charCount > 0) {
              logToConsole(`Pág. ${i}/${totalPages}: Indexados ${charCount} caracteres.`);
              // Intentar extraer transacciones de esta página
              parseTransactionsHeuristic(pageText, i);
            } else {
              logToConsole(`Pág. ${i}/${totalPages}: Alerta. No se detectó texto (página escaneada o imagen).`, "warn");
            }

            extractedPages.push({
              pageNum: i,
              text: pageText,
              charsCount: charCount
            });
          }

          updateProgressBar(100, "¡Indexación y Extracción de Transacciones lista!");
          logToConsole(`Análisis completado. Se autodetectaron ${extractedTransactions.length} posibles transacciones.`, "success");

          setTimeout(() => {
            progressContainer.classList.add('hidden');
            renderUIWithDocument(totalPages);
          }, 800);

        } catch (error) {
          console.error("Fallo de lectura:", error);
          logToConsole(`ERROR CRÍTICO: No se pudo analizar el PDF. ${error.message}`, "warn");
          showToast("Error al indexar el PDF. Podría estar protegido.", "error");
          resetApplication();
        }
      };

      reader.onerror = function() {
        showToast("Error en el FileReader local.", "error");
        resetApplication();
      };

      reader.readAsArrayBuffer(file);
    }

    function updateProgressBar(percent, text) {
      progressBar.style.width = `${percent}%`;
      progressPercent.textContent = `${percent}%`;
      progressStatus.textContent = text;
    }

    // --- ALGORITMO HEURÍSTICO DE EXTRACCIÓN DE TRANSACCIONES ---
    // Busca patrones de: Fecha, N° Operación, Descripción, Abonos
    function parseTransactionsHeuristic(text, pageNum) {
      // 1. Buscamos líneas o secciones individuales dividiendo el texto por espacios amplios o saltos sugeridos
      const lines = text.split(/(?:\s{3,}|\n|(?=\b\d{1,2}[/-]\d{1,2}[/-]\d{2,4}\b))/);
      
      lines.forEach(line => {
        const trimmed = line.trim();
        if (trimmed.length < 15) return; // Línea muy corta probablemente no es transacción

        // Buscar Fecha
        const dateRegex = /\b(\d{1,2}[/-]\d{1,2}[/-]\d{2,4})\b/;
        const dateMatch = trimmed.match(dateRegex);
        if (!dateMatch) return; // Si la fila no tiene una fecha, no la consideramos transacción válida para nuestro reporte

        const fechaStr = dateMatch[1];

        // Buscar Número de Operación (op, ref, trx, trx, nro, num, o simplemente secuencias de 5 a 12 dígitos)
        const opRegex = /(?:op(?:eración|eracion|er)?\.?|ref(?:erencia)?\.?|n(?:ro|um|°)?\.?|trans(?:acción)?\.?)\s*[:#\-]?\s*(\d{4,12})\b/i;
        let opMatch = trimmed.match(opRegex);
        let operacionStr = "";

        if (opMatch) {
          operacionStr = opMatch[1];
        } else {
          // Si no tiene prefijo, buscamos secuencias de números que parezcan ID de operación de 5 a 10 dígitos (distinto del año)
          const generalNumRegex = /\b\d{5,10}\b/g;
          let m;
          while ((m = generalNumRegex.exec(trimmed)) !== null) {
            if (m[0] !== fechaStr.split(/[/-]/).pop()) { // Evitar confundir con el año
              operacionStr = m[0];
              break;
            }
          }
        }

        if (!operacionStr) {
          operacionStr = "N/D"; // No Detectado
        }

        // Buscar Abonos (Cantidades de dinero)
        // Heurística: Números con formato decimal en la línea, que no formen parte de la fecha ni de la operación.
        // Soporta formatos comunes: $12.345,67, $ 1,234.56, 1500.00, 350.000, etc.
        const moneyRegex = /(?:\$\s*)?\b\d{1,3}(?:\.\d{3})*(?:,\d{2})\b|(?:\$\s*)?\b\d+[\.,]\d{2}\b/g;
        let moneyMatches = trimmed.match(moneyRegex);
        let abonoVal = 0;
        let abonoStr = "0.00";

        if (moneyMatches && moneyMatches.length > 0) {
          // Heurística de Abono/Ingreso vs Cargo/Egreso:
          // Normalmente las cifras más altas en un listado o las que están al final de la línea corresponden a abonos o saldos.
          // Para nuestro buscador, tomamos el valor que parezca representar el movimiento.
          // Filtramos números sospechosos que se parezcan a años (ej. 2026.00) u operaciones.
          const cleanAmounts = moneyMatches.map(m => {
            const raw = m.replace(/[^\d.,]/g, ''); // Dejar solo dígitos, coma y punto
            // Detectar separador decimal
            let val = 0;
            if (raw.includes(',') && raw.includes('.')) {
              // Formato europeo/latam: 1.234,56
              val = parseFloat(raw.replace(/\./g, '').replace(',', '.'));
            } else if (raw.includes(',')) {
              // Podría ser decimal simple 1234,56 o miles 1,234
              const parts = raw.split(',');
              if (parts[parts.length - 1].length === 2) {
                val = parseFloat(raw.replace(',', '.'));
              } else {
                val = parseFloat(raw.replace(/,/g, ''));
              }
            } else {
              val = parseFloat(raw);
            }
            return { text: m, val: val };
          }).filter(item => item.val > 0 && item.val !== parseInt(operacionStr) && item.val < 10000000); // Filtros de seguridad

          if (cleanAmounts.length > 0) {
            // Asumimos el mayor o el último valor detectado de dinero en la fila como el Abono
            const chosen = cleanAmounts[cleanAmounts.length - 1]; 
            abonoVal = chosen.val;
            abonoStr = abonoVal.toFixed(2);
          }
        }

        // Descripción (Todo lo que queda excluyendo la fecha, número de operación y montos)
        let descripcionStr = trimmed
          .replace(fechaStr, "")
          .replace(operacionStr, "")
          .replace(/(?:op(?:eración|eracion|er)?\.?|ref(?:erencia)?\.?|n(?:ro|um|°)?\.?|trans(?:acción)?\.?)\s*[:#\-]?/gi, "")
          .replace(/[\$\d\.,\-\/]{4,}/g, "") // remover montos y cadenas numéricas largas
          .replace(/\s+/g, " ")
          .trim();

        if (descripcionStr.length < 5) {
          descripcionStr = "Transacción / Operación Registrada";
        }

        // Añadir si pasa criterios mínimos de calidad
        extractedTransactions.push({
          id: 'trx_' + Math.random().toString(36).substr(2, 9),
          page: pageNum,
          fecha: fechaStr,
          operacion: operacionStr,
          descripcion: descripcionStr,
          abono: abonoVal
        });
      });
    }

    // --- RENDERIZADO DEL WORKSPACE ---
    function renderUIWithDocument(totalPages) {
      loadedDocName.textContent = pdfFileName;
      loadedDocPages.textContent = `(${totalPages} ${totalPages === 1 ? 'página' : 'páginas'} analizadas en total)`;
      
      updateSummaryMetrics();

      docMetaInfo.classList.remove('hidden');
      searchWorkspace.classList.remove('hidden');

      // Volver a pestaña por defecto
      switchTab("pages");

      // Cargar lista inicial
      performSearch();
      renderTransactionsTable();
      showToast(`¡Análisis completo! Se extrajo el contenido de las ${totalPages} páginas.`, "success");
    }

    function updateSummaryMetrics() {
      badgeTotalTransactions.textContent = `${extractedTransactions.length} transacciones detectadas`;
      tableSummaryCount.textContent = extractedTransactions.length;
      
      const totalSum = extractedTransactions.reduce((acc, curr) => acc + curr.abono, 0);
      tableSummarySum.textContent = `$${totalSum.toLocaleString('es-ES', { minimumFractionDigits: 2, maximumFractionDigits: 2 })}`;
    }

    // --- LÓGICA DE GESTIÓN DE PESTAÑAS ---
    function switchTab(tabId) {
      currentActiveTab = tabId;
      if (tabId === "pages") {
        tabButtonPages.className = "flex-1 py-2.5 text-xs sm:text-sm font-bold rounded-xl transition-all bg-indigo-50 text-indigo-700 shadow-2xs";
        tabButtonTable.className = "flex-1 py-2.5 text-xs sm:text-sm font-bold rounded-xl transition-all text-slate-600 hover:bg-slate-50";
        tabContentPages.classList.remove('hidden');
        tabContentTable.classList.add('hidden');
      } else {
        tabButtonTable.className = "flex-1 py-2.5 text-xs sm:text-sm font-bold rounded-xl transition-all bg-indigo-50 text-indigo-700 shadow-2xs";
        tabButtonPages.className = "flex-1 py-2.5 text-xs sm:text-sm font-bold rounded-xl transition-all text-slate-600 hover:bg-slate-50";
        tabContentTable.classList.remove('hidden');
        tabContentPages.classList.add('hidden');
        // Refrescar tabla por si hubo cambios de filtro
        renderTransactionsTable();
      }
    }

    tabButtonPages.addEventListener('click', () => switchTab("pages"));
    tabButtonTable.addEventListener('click', () => switchTab("table"));

    // --- ALGORITMO DE BÚSQUEDA ---
    function performSearch() {
      const query = searchQueryInput.value.trim().toLowerCase();
      const filteredResults = [];

      extractedPages.forEach(page => {
        let textMatches = true;

        if (query.length > 0) {
          textMatches = page.text.toLowerCase().includes(query);
        }

        if (textMatches) {
          let snippet = "";
          if (query.length > 0) {
            const index = page.text.toLowerCase().indexOf(query);
            const start = Math.max(0, index - 40);
            const end = Math.min(page.text.length, index + query.length + 50);
            snippet = page.text.slice(start, end);
            if (start > 0) snippet = "..." + snippet;
            if (end < page.text.length) snippet = snippet + "...";
          } else {
            snippet = page.text.substring(0, 100) + (page.text.length > 100 ? "..." : "");
          }

          if (page.charsCount === 0) {
            snippet = "[Página sin texto estructurado. Usa el Render Visual]";
          }

          filteredResults.push({
            pageNum: page.pageNum,
            fullText: page.text,
            snippet: snippet,
            isEmpty: page.charsCount === 0
          });
        }
      });

      renderResultsList(filteredResults, query);
      
      // Si estamos en la pestaña de tabla, filtrar también la tabla
      if (currentActiveTab === "table") {
        renderTransactionsTable();
      }
    }

    // --- DIBUJAR LISTA DE RESULTADOS ---
    function renderResultsList(results, activeQuery) {
      resultsCount.textContent = results.length;
      resultsList.innerHTML = "";

      if (results.length === 0) {
        resultsList.innerHTML = `
          <div class="text-center py-20 text-slate-400">
            <svg class="w-12 h-12 text-slate-300 mx-auto mb-2.5" fill="none" stroke="currentColor" viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9.172 16.172a4 4 0 015.656 0M9 10h.01M15 10h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z"></path>
            </svg>
            <p class="text-sm font-bold text-slate-600">No se encontraron coincidencias</p>
            <p class="text-xs mt-1">Refina el término buscado.</p>
          </div>
        `;
        return;
      }

      results.forEach(res => {
        const card = document.createElement('div');
        card.className = `p-4 rounded-xl border transition-all cursor-pointer text-left flex flex-col gap-2 ${
          activeResultPageNum === res.pageNum 
            ? 'bg-indigo-50/75 border-indigo-500 shadow-xs ring-1 ring-indigo-500/20' 
            : 'bg-slate-50 hover:bg-slate-100 border-slate-200 hover:border-slate-300'
        }`;
        
        let highlightedSnippet = res.snippet;
        if (activeQuery.length > 0 && !res.isEmpty) {
          const regex = new RegExp(`(${escapeRegExp(activeQuery)})`, 'gi');
          highlightedSnippet = res.snippet.replace(regex, '<mark class="highlight-match">$1</mark>');
        }

        // Buscar transacciones asociadas a esta página para mostrarlas resumidas
        const trxsOnPage = extractedTransactions.filter(t => t.page === res.pageNum);
        let badgeTrxs = "";
        if (trxsOnPage.length > 0) {
          badgeTrxs = `<span class="bg-indigo-100 text-indigo-800 text-[10px] px-2 py-0.5 rounded-full font-bold">${trxsOnPage.length} transacciones</span>`;
        }

        card.innerHTML = `
          <div class="flex justify-between items-center">
            <div class="flex items-center gap-2">
              <span class="bg-indigo-600 text-white text-xs font-bold px-2 py-0.5 rounded-md">Pág. ${res.pageNum}</span>
              ${badgeTrxs}
            </div>
            <span class="text-[11px] text-slate-400 font-medium">
              ${res.fullText.length} carac.
            </span>
          </div>
          <p class="text-xs text-slate-600 font-normal italic bg-white p-2.5 rounded-lg border border-slate-100 line-clamp-2 leading-relaxed">
            ${highlightedSnippet}
          </p>
        `;

        card.addEventListener('click', () => {
          selectActiveResult(res.pageNum);
        });

        resultsList.appendChild(card);
      });

      if (results.length > 0 && !activeResultPageNum) {
        selectActiveResult(results[0].pageNum);
      }
    }

    function escapeRegExp(string) {
      return string.replace(/[.*+?^${}()|[\]\\]/g, '\\$&');
    }

    function selectActiveResult(pageNum) {
      activeResultPageNum = pageNum;
      activePageIndicator.textContent = `Página ${pageNum} de ${currentPdfDoc.numPages}`;
      
      performSearchKeepSelection();
      renderActivePage();
    }

    function performSearchKeepSelection() {
      const query = searchQueryInput.value.trim().toLowerCase();
      const filteredResults = [];

      extractedPages.forEach(page => {
        let textMatches = true;

        if (query.length > 0) {
          textMatches = page.text.toLowerCase().includes(query);
        }

        if (textMatches) {
          let snippet = "";
          if (query.length > 0) {
            const index = page.text.toLowerCase().indexOf(query);
            const start = Math.max(0, index - 40);
            const end = Math.min(page.text.length, index + query.length + 50);
            snippet = page.text.slice(start, end);
            if (start > 0) snippet = "..." + snippet;
            if (end < page.text.length) snippet = snippet + "...";
          } else {
            snippet = page.text.substring(0, 100) + (page.text.length > 100 ? "..." : "");
          }

          if (page.charsCount === 0) {
            snippet = "[Página sin texto estructurado. Usa el Render Visual]";
          }

          filteredResults.push({
            pageNum: page.pageNum,
            fullText: page.text,
            snippet: snippet,
            isEmpty: page.charsCount === 0
          });
        }
      });

      renderResultsList(filteredResults, query);
    }

    // --- VISUALIZAR LA PÁGINA SELECCIONADA ---
    async function renderActivePage() {
      if (!currentPdfDoc || !activeResultPageNum) return;

      const pageData = extractedPages.find(p => p.pageNum === activeResultPageNum);
      if (pageData) {
        if (pageData.charsCount === 0) {
          plainTextContainer.innerHTML = `<span class="text-slate-400 italic">No se pudo extraer texto plano de esta página. Cambia a "Página Real (Render)" en la parte superior para visualizarla.</span>`;
        } else {
          const query = searchQueryInput.value.trim();
          let formattedText = pageData.text;

          if (query.length > 0) {
            const regex = new RegExp(`(${escapeRegExp(query)})`, 'gi');
            formattedText = pageData.text.replace(regex, '<mark class="bg-yellow-300 text-slate-900 px-1 font-bold rounded-xs">$1</mark>');
          }
          plainTextContainer.innerHTML = formattedText;
        }
      }

      renderLoader.classList.remove('hidden');
      try {
        const page = await currentPdfDoc.getPage(activeResultPageNum);
        const viewport = page.getViewport({ scale: 1.5 });
        
        pdfPageCanvas.height = viewport.height;
        pdfPageCanvas.width = viewport.width;

        const renderContext = {
          canvasContext: canvasContext,
          viewport: viewport
        };

        await page.render(renderContext).promise;
      } catch (error) {
        console.error("Error al pintar canvas:", error);
      } finally {
        renderLoader.classList.add('hidden');
      }
    }

    // --- LOGICA DEL EDITOR DE TABLA DE TRANSACCIONES ---
    function renderTransactionsTable() {
      transactionsTableBody.innerHTML = "";
      const query = searchQueryInput.value.trim().toLowerCase();

      // Filtrar filas de la tabla de acuerdo al buscador general (si hay consulta activa)
      const filteredTrxs = extractedTransactions.filter(t => {
        if (query.length === 0) return true;
        return t.fecha.toLowerCase().includes(query) ||
               t.operacion.toLowerCase().includes(query) ||
               t.descripcion.toLowerCase().includes(query) ||
               t.abono.toString().includes(query);
      });

      if (filteredTrxs.length === 0) {
        transactionsTableBody.innerHTML = `
          <tr>
            <td colspan="6" class="text-center py-10 text-slate-400 italic">
              No se encontraron filas que coincidan con el filtro actual.
            </td>
          </tr>
        `;
        return;
      }

      filteredTrxs.forEach(t => {
        const row = document.createElement('tr');
        row.className = "hover:bg-slate-50/80 transition-colors";
        row.innerHTML = `
          <td class="py-2.5 px-4 text-center font-bold text-slate-500">${t.page}</td>
          <td class="py-2.5 px-4">
            <input type="text" value="${t.fecha}" class="w-full bg-transparent hover:bg-white focus:bg-white border border-transparent focus:border-indigo-400 focus:ring-1 focus:ring-indigo-400 rounded-md px-1.5 py-0.5 transition-all" onchange="updateTransactionField('${t.id}', 'fecha', this.value)" />
          </td>
          <td class="py-2.5 px-4">
            <input type="text" value="${t.operacion}" class="w-full bg-transparent hover:bg-white focus:bg-white border border-transparent focus:border-indigo-400 focus:ring-1 focus:ring-indigo-400 rounded-md px-1.5 py-0.5 transition-all" onchange="updateTransactionField('${t.id}', 'operacion', this.value)" />
          </td>
          <td class="py-2.5 px-4">
            <input type="text" value="${t.descripcion}" class="w-full bg-transparent hover:bg-white focus:bg-white border border-transparent focus:border-indigo-400 focus:ring-1 focus:ring-indigo-400 rounded-md px-1.5 py-0.5 transition-all" onchange="updateTransactionField('${t.id}', 'descripcion', this.value)" />
          </td>
          <td class="py-2.5 px-4 text-right">
            <input type="number" step="0.01" value="${t.abono}" class="w-full bg-transparent hover:bg-white focus:bg-white border border-transparent focus:border-indigo-400 focus:ring-1 focus:ring-indigo-400 rounded-md px-1.5 py-0.5 text-right font-bold text-indigo-700 transition-all" onchange="updateTransactionField('${t.id}', 'abono', this.value)" />
          </td>
          <td class="py-2.5 px-4 text-center">
            <button onclick="deleteTransactionRow('${t.id}')" class="text-slate-400 hover:text-red-600 p-1 rounded-md hover:bg-red-50 transition-colors" title="Eliminar fila">
              <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 7l-.867 12.142A2 2 0 0116.138 21H7.862a2 2 0 01-1.995-1.858L5 7m5 4v6m4-6v6m1-10V4a1 1 0 00-1-1h-4a1 1 0 00-1 1v3M4 7h16"></path>
              </svg>
            </button>
          </td>
        `;
        transactionsTableBody.appendChild(row);
      });
    }

    // Funciones globales de edición directa para la tabla de transacciones
    window.updateTransactionField = function(id, field, value) {
      const idx = extractedTransactions.findIndex(t => t.id === id);
      if (idx !== -1) {
        if (field === 'abono') {
          extractedTransactions[idx][field] = parseFloat(value) || 0;
        } else {
          extractedTransactions[idx][field] = value;
        }
        updateSummaryMetrics();
      }
    };

    window.deleteTransactionRow = function(id) {
      extractedTransactions = extractedTransactions.filter(t => t.id !== id);
      updateSummaryMetrics();
      renderTransactionsTable();
      showToast("Fila eliminada con éxito.", "info");
    };

    // Añadir fila manual
    btnAddRow.addEventListener('click', () => {
      const newTrx = {
        id: 'trx_' + Math.random().toString(36).substr(2, 9),
        page: activeResultPageNum || 1,
        fecha: new Date().toLocaleDateString('es-ES'),
        operacion: "MANUAL",
        descripcion: "Nueva transacción añadida manualmente",
        abono: 0.00
      };
      extractedTransactions.unshift(newTrx); // Al principio
      updateSummaryMetrics();
      renderTransactionsTable();
      showToast("Se agregó una nueva fila editable.", "success");
    });

    // Re-Escanear PDF buscando patrones adicionales
    btnAutoParse.addEventListener('click', () => {
      if (extractedPages.length === 0) return;
      extractedTransactions = [];
      extractedPages.forEach(p => {
        parseTransactionsHeuristic(p.text, p.pageNum);
      });
      updateSummaryMetrics();
      renderTransactionsTable();
      showToast("Análisis heurístico completado nuevamente.", "success");
    });


    // --- LÓGICA DE EXPORTACIÓN (EXCEL & PDF) ---

    // EXPORTAR A EXCEL (XLSX)
    btnExportExcel.addEventListener('click', () => {
      if (extractedTransactions.length === 0) {
        showToast("No hay datos cargados en la tabla para exportar.", "error");
        return;
      }

      try {
        const query = searchQueryInput.value.trim().toLowerCase();
        
        // Obtener datos respetando el filtro actual de la interfaz
        const filteredData = extractedTransactions.filter(t => {
          if (query.length === 0) return true;
          return t.fecha.toLowerCase().includes(query) ||
                 t.operacion.toLowerCase().includes(query) ||
                 t.descripcion.toLowerCase().includes(query) ||
                 t.abono.toString().includes(query);
        });

        // Mapear al formato final de columnas solicitado
        const exportRows = filteredData.map(t => ({
          "Página": t.page,
          "Fecha": t.fecha,
          "N° Operación": t.operacion,
          "Descripción": t.descripcion,
          "Abono ($)": t.abono
        }));

        // Crear Libro y Hoja de Cálculo
        const worksheet = XLSX.utils.json_to_sheet(exportRows);
        const workbook = XLSX.utils.book_new();
        XLSX.utils.book_append_sheet(workbook, worksheet, "Transacciones");

        // Ajustar auto-anchos de columnas
        const maxAnchos = [
          { wch: 8 },  // Página
          { wch: 15 }, // Fecha
          { wch: 18 }, // N° Operación
          { wch: 45 }, // Descripción
          { wch: 15 }  // Abono
        ];
        worksheet["!cols"] = maxAnchos;

        // Escribir archivo local
        const excelName = pdfFileName.replace(/\.[^/.]+$/, "") + "_Resultados.xlsx";
        XLSX.writeFile(workbook, excelName);
        showToast(`Documento Excel exportado como ${excelName}`, "success");
      } catch (err) {
        console.error(err);
        showToast("No se pudo generar el archivo de Excel.", "error");
      }
    });

    // EXPORTAR A PDF (REPORT TABULAR)
    btnExportPDF.addEventListener('click', () => {
      if (extractedTransactions.length === 0) {
        showToast("No hay datos en la tabla para exportar a PDF.", "error");
        return;
      }

      try {
        const query = searchQueryInput.value.trim().toLowerCase();
        
        // Filtrar datos igual que en pantalla
        const filteredData = extractedTransactions.filter(t => {
          if (query.length === 0) return true;
          return t.fecha.toLowerCase().includes(query) ||
                 t.operacion.toLowerCase().includes(query) ||
                 t.descripcion.toLowerCase().includes(query) ||
                 t.abono.toString().includes(query);
        });

        // Crear instancia de jsPDF
        const { jsPDF } = window.jspdf;
        const doc = new jsPDF({
          orientation: 'portrait',
          unit: 'mm',
          format: 'a4'
        });

        // Título del PDF
        doc.setFontSize(18);
        doc.setTextColor(30, 41, 59); // Slate-800
        doc.text("Reporte de Transacciones Extraídas", 14, 20);
        
        doc.setFontSize(10);
        doc.setTextColor(100, 116, 139); // Slate-500
        doc.text(`Documento de origen: ${pdfFileName}`, 14, 26);
        doc.text(`Fecha del Reporte: ${new Date().toLocaleString()}`, 14, 31);
        
        if (query) {
          doc.text(`Filtro de búsqueda aplicado: "${query}"`, 14, 36);
        }

        // Mapear datos a formato matriz para autoTable
        const tableBody = filteredData.map(t => [
          t.page,
          t.fecha,
          t.operacion,
          t.descripcion,
          `$${t.abono.toLocaleString('es-ES', { minimumFractionDigits: 2, maximumFractionDigits: 2 })}`
        ]);

        const totalSum = filteredData.reduce((acc, curr) => acc + curr.abono, 0);

        // Generar AutoTable
        doc.autoTable({
          head: [['Pág', 'Fecha', 'N° Operación', 'Descripción', 'Abono']],
          body: tableBody,
          startY: query ? 40 : 36,
          theme: 'striped',
          headStyles: { fillHexColor: '#4f46e5', textColor: '#ffffff', fontStyle: 'bold' }, // Indigo-600
          styles: { fontSize: 8.5, cellPadding: 2.5 },
          columnStyles: {
            0: { halign: 'center', cellWidth: 10 },
            1: { cellWidth: 28 },
            2: { cellWidth: 32 },
            3: { cellWidth: 'auto' },
            4: { halign: 'right', cellWidth: 26 }
          },
          foot: [[
            '', '', '', 
            'MONTO TOTAL ACUMULADO:', 
            `$${totalSum.toLocaleString('es-ES', { minimumFractionDigits: 2, maximumFractionDigits: 2 })}`
          ]],
          footStyles: { fillHexColor: '#f1f5f9', textColor: '#1e293b', fontStyle: 'bold', halign: 'right' },
          margin: { top: 30, bottom: 20 }
        });

        const pdfName = pdfFileName.replace(/\.[^/.]+$/, "") + "_Resultados.pdf";
        doc.save(pdfName);
        showToast(`Documento PDF exportado como ${pdfName}`, "success");
      } catch (err) {
        console.error(err);
        showToast("Error al compilar el reporte PDF.", "error");
      }
    });


    // --- ACCIONES GENERALES DEL BUSCADOR ---

    viewModeVisualBtn.addEventListener('click', () => {
      currentViewMode = "visual";
      viewModeVisualBtn.className = "py-1.5 rounded-md bg-white shadow-xs text-indigo-700 font-semibold focus:outline-none";
      viewModeTextBtn.className = "py-1.5 rounded-md text-slate-600 hover:bg-white/50 focus:outline-none";
      visualCanvasContainer.classList.remove('hidden');
      plainTextContainer.classList.add('hidden');
    });

    viewModeTextBtn.addEventListener('click', () => {
      currentViewMode = "text";
      viewModeTextBtn.className = "py-1.5 rounded-md bg-white shadow-xs text-indigo-700 font-semibold focus:outline-none";
      viewModeVisualBtn.className = "py-1.5 rounded-md text-slate-600 hover:bg-white/50 focus:outline-none";
      plainTextContainer.classList.remove('hidden');
      visualCanvasContainer.classList.add('hidden');
    });

    searchQueryInput.addEventListener('input', () => {
      if (searchQueryInput.value.length > 0) {
        btnClearText.classList.remove('hidden');
      } else {
        btnClearText.classList.add('hidden');
      }
    });

    btnClearText.addEventListener('click', () => {
      searchQueryInput.value = "";
      btnClearText.classList.add('hidden');
      performSearch();
    });

    btnSearch.addEventListener('click', () => {
      activeResultPageNum = null;
      performSearch();
    });

    searchQueryInput.addEventListener('keydown', (e) => {
      if (e.key === 'Enter') {
        activeResultPageNum = null;
        performSearch();
      }
    });

    btnResetFilters.addEventListener('click', () => {
      searchQueryInput.value = "";
      btnClearText.classList.add('hidden');
      activeResultPageNum = null;
      performSearch();
      showToast("Filtros de búsqueda reiniciados.", "info");
    });

    btnReset.addEventListener('click', resetApplication);

    function resetApplication() {
      currentPdfDoc = null;
      pdfFileName = "";
      extractedPages = [];
      extractedTransactions = [];
      activeResultPageNum = null;

      searchQueryInput.value = "";
      btnClearText.classList.add('hidden');
      fileInput.value = ""; 

      docMetaInfo.classList.add('hidden');
      searchWorkspace.classList.add('hidden');
      progressContainer.classList.add('hidden');
      dropZone.classList.remove('hidden');

      canvasContext.clearRect(0, 0, pdfPageCanvas.width, pdfPageCanvas.height);
      pdfPageCanvas.width = 0;
      pdfPageCanvas.height = 0;
      activePageIndicator.textContent = "Sin selección";
      plainTextContainer.innerHTML = "Selecciona una coincidencia para visualizar el texto extraído de la página.";
    }
  </script>
</body>
</html>
